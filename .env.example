# Copy to .env and fill in. Loaded via python-dotenv at startup.

# HuggingFace token (needed to download private classifier/paraphraser adapters)
HF_TOKEN=

# Optional: where HuggingFace caches downloaded weights
# HF_HOME=

# Generation backend credentials (only what your configured models use)
OPENAI_API_KEY=
# OpenAI-compatible endpoints (OpenAI, Venice, a local vLLM OpenAI server, ...)
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
